        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.03125</item>
    </style>

    <style name="TextAppearance.BankTheme.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.0178571</item>
    </style>

    <style name="TextAppearance.BankTheme.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.0892857</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.BankTheme.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.0333333</item>
    </style>

    <style name="TextAppearance.BankTheme.Overline" parent="TextAppearance.MaterialComponents.Overline">
        <item name="fontFamily">sans-serif-medium</item>
