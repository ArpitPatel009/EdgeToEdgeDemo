        <item name="android:textSize">10sp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="titleTextColor">?attr/colorOnPrimary</item>
        <item name="subtitleTextColor">?attr/colorOnPrimary</item>
    </style>

    <!-- Chip Style -->
    <style name="BankTheme.Chip.Outline" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@android:color/transparent</item>
        <item name="chipStrokeColor">?attr/colorOnSurface</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Toggle Button Style -->
    <style name="BankTheme.Button.Toggle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/btn_compound_text</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="strokeWidth">1dp</item>
    </style>

</resources>

